#!/usr/bin/env bash

# Install a pinned Go module binary with go install.

set -euo pipefail

if [[ "$#" -ne 2 && "$#" -ne 3 ]]; then
  echo "usage: install-go-tool <module> [current-version] <version>" >&2
  exit 2
fi

readonly module="$1"
if [[ "$#" -eq 3 ]]; then
  readonly current_version="$2"
  readonly version="$3"
else
  readonly current_version=""
  readonly version="$2"
fi

case "$module" in
  "" | *@* | *[[:space:]]*)
    echo "invalid module: $module" >&2
    exit 2
    ;;
esac

case "$version" in
  "" | *@* | *[[:space:]]*)
    echo "invalid version: $version" >&2
    exit 2
    ;;
esac

if [[ "$current_version" == "$version" ]]; then
  echo "$module $version is already up to date" >&2
  exit 1
fi

go install "$module@v$version"
